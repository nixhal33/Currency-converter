pipeline {
    agent any
    
    stages {
        stage("Clone Code") {
            when { tag 'v*'}
            steps {
                echo "📦 Cloning repository..."
                git branch: 'main', credentialsId: 'github', url: 'https://github.com/nixhal33/Currency-converter.git'
                echo "✅ Clone completed"
            }
        }
        
        stage("Build Image") {
            when { tag 'v*'}
            steps {
                script {
                    TAG_NAME = env.GIT_BRANCH.replaceFirst(refs/tags/', '')
                    echo "Building Docker Image"
                    sh "docker build -t currency-convapp ."
                    echo "✅ Image built successfully"
                }
            }
        }
        
        stage("Push Image to Repository") {
            when { tag 'v*'}
            steps {
                echo "📤 Pushing image to DockerHub..."
                withCredentials([usernamePassword(credentialsId: "docker", passwordVariable: "password", usernameVariable: "user")]) {
                    sh "docker login -u ${env.user} -p ${env.password}"
                    sh "docker tag currency-convapp ${env.user}/currency-convapp:${TAG_NAME}"
                    sh "docker push ${env.user}/currency-convapp${TAG_NAME}"
                }
                echo "✅ Image pushed successfully"
            }
        }
    
    post {
        success {
            echo "🎉 Deployment successful!"
        }
        failure {
            echo "❌ Deployment failed! Check logs above."
        }
    }
}